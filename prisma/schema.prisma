generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────
// 멀티 테넌트
// ──────────────────────────────────

model Tenant {
  id              String   @id @default(uuid())
  name            String
  defaultCurrency String   @default("KRW") // ISO 4217
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships      Membership[]
  accounts         Account[]
  documents        Document[]
  journalEntries   JournalEntry[]
  vendors          Vendor[]
  periods          AccountingPeriod[]
  auditLogs        AuditLog[]
  journalTemplates JournalTemplate[]
  exchangeRates    ExchangeRate[]
  taxInvoices      TaxInvoice[]
  fixedAssets       FixedAsset[]
  approvalLines    ApprovalLine[]
  approvalRequests ApprovalRequest[]
  employees        Employee[]
  budgets          Budget[]
  projects         Project[]
  departments      Department[]
  products         Product[]
  trades           Trade[]
  payments         Payment[]
  expenseClaims    ExpenseClaim[]
  inventoryTransactions InventoryTransaction[]
  bankAccounts         BankAccount[]
  bankTransactions     BankTransaction[]
  journalRules         JournalRule[]
  taxFilings           TaxFiling[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    Membership[]
  approvalLines  ApprovalLine[]
  approvalActions ApprovalAction[]
}

// 멀티 테넌트 소속 관계
model Membership {
  id       String @id @default(uuid())
  role     String @default("USER")
  userId   String
  tenantId String
  user     User   @relation(fields: [userId], references: [id])
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ──────────────────────────────────
// 마스터
// ──────────────────────────────────

// 계정과목
model Account {
  id            String @id @default(uuid())
  code          String
  name          String
  type          String // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  normalBalance String // DEBIT, CREDIT
  tenantId      String
  tenant        Tenant @relation(fields: [tenantId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  journalLines JournalLine[]
  templateLines JournalTemplateLine[]
  fixedAssetsAsAsset         FixedAsset[] @relation("AssetAccount")
  fixedAssetsAsDepreciation  FixedAsset[] @relation("DepreciationAccount")
  fixedAssetsAsAccumulated   FixedAsset[] @relation("AccumulatedDepAccount")
  budgets                    Budget[]
  bankAccounts               BankAccount[]
  journalRulesAsDebit        JournalRule[] @relation("DebitAccount")
  journalRulesAsCredit       JournalRule[] @relation("CreditAccount")

  @@unique([tenantId, code])
  @@index([tenantId])
}

// 전표 자동 생성 규칙
model JournalRule {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String
  vendorName      String?
  keywords        String?
  amountMin       Decimal? @db.Decimal(18, 2)
  amountMax       Decimal? @db.Decimal(18, 2)
  debitAccountId  String
  debitAccount    Account  @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccountId String
  creditAccount   Account  @relation("CreditAccount", fields: [creditAccountId], references: [id])
  priority        Int      @default(0)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}

// 거래처
model Vendor {
  id        String @id @default(uuid())
  name      String
  bizNo     String? // 사업자등록번호
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents    Document[]
  journalLines JournalLine[]
  templateLines JournalTemplateLine[]
  taxInvoices  TaxInvoice[]
  trades       Trade[]

  @@unique([tenantId, bizNo])
  @@index([tenantId])
}

// 회계 기간 (결산/마감)
model AccountingPeriod {
  id        String    @id @default(uuid())
  year      Int
  month     Int
  status    String    @default("OPEN") // OPEN, CLOSED
  closedAt  DateTime?
  closedBy  String?   // User ID
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, year, month])
  @@index([tenantId])
}

// 감사 로그
model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  userId      String
  action      String   // JOURNAL_CREATED, JOURNAL_UPDATED, JOURNAL_DELETED, JOURNAL_BATCH_STATUS, PERIOD_CLOSED, PERIOD_REOPENED
  entityType  String   // JournalEntry, AccountingPeriod
  entityId    String
  description String?
  oldValue    Json?
  newValue    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}

// ──────────────────────────────────
// 증빙
// ──────────────────────────────────

// 영수증
model Document {
  id            String   @id @default(uuid())
  vendorName    String?
  transactionAt DateTime?
  totalAmount   Decimal? @db.Decimal(18, 2)
  currency      String   @default("KRW") // ISO 4217
  status        String   @default("PENDING") // PENDING, OCR_DONE, JOURNAL_CREATED
  ocrRaw        Json?
  imageUrl      String?
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  vendorId      String?
  vendor        Vendor?  @relation(fields: [vendorId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  journalEntry JournalEntry?

  @@index([tenantId])
  @@index([status])
}

// ──────────────────────────────────
// 회계
// ──────────────────────────────────

// 전표 헤더
model JournalEntry {
  id          String   @id @default(uuid())
  date        DateTime
  description String?
  status       String   @default("DRAFT") // DRAFT, APPROVED, POSTED
  currency     String   @default("KRW") // ISO 4217
  exchangeRate Decimal  @default(1) @db.Decimal(18, 6) // 1 외화 = rate 기준통화
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  documentId  String?  @unique
  document    Document? @relation(fields: [documentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalLine[]
  attachments JournalAttachment[]
  taxInvoice  TaxInvoice?
  depreciationRecords DepreciationRecord[]
  payrollRecords PayrollRecord[]
  trade          Trade?
  payment        Payment?
  expenseClaim          ExpenseClaim?
  inventoryTransaction  InventoryTransaction?
  bankTransaction       BankTransaction?

  @@index([tenantId])
  @@index([date])
}

// 전표 라인 (차변/대변)
model JournalLine {
  id             String       @id @default(uuid())
  debit          Decimal      @default(0) @db.Decimal(18, 2)
  credit         Decimal      @default(0) @db.Decimal(18, 2)
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  vendorId       String?
  vendor         Vendor?      @relation(fields: [vendorId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([journalEntryId])
  @@index([accountId])
  @@index([vendorId])
  @@index([projectId])
  @@index([departmentId])
}

// 전표 첨부파일
model JournalAttachment {
  id             String       @id @default(uuid())
  filename       String
  url            String
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([journalEntryId])
}

// ──────────────────────────────────
// 반복 전표 템플릿
// ──────────────────────────────────

model JournalTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalTemplateLine[]

  @@index([tenantId])
}

model JournalTemplateLine {
  id                String          @id @default(uuid())
  debit             Decimal         @default(0) @db.Decimal(18, 2)
  credit            Decimal         @default(0) @db.Decimal(18, 2)
  journalTemplateId String
  journalTemplate   JournalTemplate @relation(fields: [journalTemplateId], references: [id], onDelete: Cascade)
  accountId         String
  account           Account         @relation(fields: [accountId], references: [id])
  vendorId          String?
  vendor            Vendor?         @relation(fields: [vendorId], references: [id])

  @@index([journalTemplateId])
}

// ──────────────────────────────────
// 환율 관리
// ──────────────────────────────────

model ExchangeRate {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  currency  String   // USD, EUR, JPY, CNY 등 ISO 4217
  rate      Decimal  @db.Decimal(18, 6) // 1 외화 = rate 기준통화
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([tenantId, currency, date])
  @@index([tenantId])
}

// ──────────────────────────────────
// 세금계산서
// ──────────────────────────────────

model TaxInvoice {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  invoiceType     String    // PURCHASE (매입), SALES (매출)
  invoiceNo       String?   // 세금계산서 번호
  invoiceDate     DateTime  // 발행일
  status          String    @default("DRAFT") // DRAFT, APPROVED, FINALIZED

  // 공급자
  issuerBizNo     String    // 사업자등록번호
  issuerName      String    // 상호

  // 공급받는자
  recipientBizNo  String
  recipientName   String

  // 금액
  supplyAmount    Decimal   @db.Decimal(18, 2) // 공급가액
  taxAmount       Decimal   @db.Decimal(18, 2) // 세액
  totalAmount     Decimal   @db.Decimal(18, 2) // 합계

  // 전자세금계산서 승인
  approvalNo      String?   // 국세청 승인번호

  // 거래처 연결
  vendorId        String?
  vendor          Vendor?   @relation(fields: [vendorId], references: [id])

  // 전표 연결
  journalEntryId  String?   @unique
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])

  description        String?

  // 홈택스 연동
  hometaxSyncStatus  String?    // IMPORTED, EXPORTED, VERIFIED
  hometaxImportedAt  DateTime?
  xmlRaw             String?    // 원본 XML 저장

  items              TaxInvoiceItem[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([invoiceDate])
  @@index([invoiceType])
}

// ──────────────────────────────────
// 고정자산
// ──────────────────────────────────

model FixedAsset {
  id                      String    @id @default(uuid())
  name                    String
  description             String?
  tenantId                String
  tenant                  Tenant    @relation(fields: [tenantId], references: [id])

  // 계정 연결
  assetAccountId          String    // 자산 계정 (13100 토지, 13200 건물, 13500 비품)
  assetAccount            Account   @relation("AssetAccount", fields: [assetAccountId], references: [id])
  depreciationAccountId   String    // 감가상각비 계정 (50900)
  depreciationAccount     Account   @relation("DepreciationAccount", fields: [depreciationAccountId], references: [id])
  accumulatedDepAccountId String    // 감가상각누계액 계정 (13600)
  accumulatedDepAccount   Account   @relation("AccumulatedDepAccount", fields: [accumulatedDepAccountId], references: [id])

  // 자산 정보
  acquisitionDate         DateTime
  acquisitionCost         Decimal   @db.Decimal(18, 2)
  usefulLifeMonths        Int       // 내용연수 (월 단위)
  residualValue           Decimal   @default(0) @db.Decimal(18, 2) // 잔존가치
  depreciationMethod      String    // STRAIGHT_LINE, DECLINING_BALANCE

  // 상태
  status                  String    @default("ACTIVE") // ACTIVE, DISPOSED, FULLY_DEPRECIATED
  disposalDate            DateTime?
  disposalAmount          Decimal?  @db.Decimal(18, 2)

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  depreciationRecords     DepreciationRecord[]

  @@index([tenantId])
}

model DepreciationRecord {
  id                String       @id @default(uuid())
  fixedAssetId      String
  fixedAsset        FixedAsset   @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)
  period            String       // YYYY-MM
  amount            Decimal      @db.Decimal(18, 2) // 당기 감가상각액
  accumulatedAmount Decimal      @db.Decimal(18, 2) // 누적 감가상각액
  bookValue         Decimal      @db.Decimal(18, 2) // 장부가액

  // 전표 연결
  journalEntryId    String?
  journalEntry      JournalEntry? @relation(fields: [journalEntryId], references: [id])

  createdAt         DateTime     @default(now())

  @@unique([fixedAssetId, period])
  @@index([fixedAssetId])
}

// ──────────────────────────────────
// 전자결재
// ──────────────────────────────────

// 결재선 설정
model ApprovalLine {
  id           String @id @default(uuid())
  tenantId     String
  tenant       Tenant @relation(fields: [tenantId], references: [id])
  documentType String // JOURNAL, TAX_INVOICE
  step         Int    // 결재 순서 (1, 2, 3...)
  approverId   String
  approver     User   @relation(fields: [approverId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([tenantId, documentType, step])
  @@index([tenantId])
}

// 결재 요청
model ApprovalRequest {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  documentType String   // JOURNAL, TAX_INVOICE
  documentId   String   // 전표/세금계산서 ID
  currentStep  Int      @default(1)
  totalSteps   Int
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  submittedBy  String   // 요청자 User ID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  actions      ApprovalAction[]

  @@index([tenantId])
  @@index([documentType, documentId])
}

// 결재 처리 이력
model ApprovalAction {
  id                String          @id @default(uuid())
  approvalRequestId String
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  step              Int
  approverId        String
  approver          User            @relation(fields: [approverId], references: [id])
  action            String          // APPROVED, REJECTED
  comment           String?
  createdAt         DateTime        @default(now())

  @@index([approvalRequestId])
}

// ──────────────────────────────────
// 급여 관리
// ──────────────────────────────────

model Employee {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  employeeNo   String
  name         String
  department   String?
  position     String?
  joinDate     DateTime
  leaveDate    DateTime?
  status       String    @default("ACTIVE") // ACTIVE, INACTIVE
  baseSalary   Decimal   @db.Decimal(18, 2) // 월 기본급
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  payrollRecords      PayrollRecord[]
  expenseClaims       ExpenseClaim[]
  yearEndSettlements  YearEndSettlement[]

  @@unique([tenantId, employeeNo])
  @@index([tenantId])
}

model PayrollRecord {
  id                  String        @id @default(uuid())
  employeeId          String
  employee            Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period              String        // YYYY-MM

  // 지급
  baseSalary          Decimal       @db.Decimal(18, 2)
  overtimePay         Decimal       @default(0) @db.Decimal(18, 2)
  bonusPay            Decimal       @default(0) @db.Decimal(18, 2)
  grossPay            Decimal       @db.Decimal(18, 2) // 총지급액

  // 공제 (개인부담)
  nationalPension     Decimal       @db.Decimal(18, 2) // 국민연금
  healthInsurance     Decimal       @db.Decimal(18, 2) // 건강보험
  longTermCare        Decimal       @db.Decimal(18, 2) // 장기요양보험
  employmentInsurance Decimal       @db.Decimal(18, 2) // 고용보험
  incomeTax           Decimal       @db.Decimal(18, 2) // 소득세
  localIncomeTax      Decimal       @db.Decimal(18, 2) // 지방소득세

  totalDeduction      Decimal       @db.Decimal(18, 2) // 총공제액
  netPay              Decimal       @db.Decimal(18, 2) // 실수령액

  // 전표 연결
  journalEntryId      String?
  journalEntry        JournalEntry? @relation(fields: [journalEntryId], references: [id])

  createdAt           DateTime      @default(now())

  @@unique([employeeId, period])
  @@index([employeeId])
}

// ──────────────────────────────────
// 예산 관리
// ──────────────────────────────────

model Budget {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
  year      Int
  month     Int      // 1-12
  amount    Decimal  @db.Decimal(18, 2)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, accountId, year, month])
  @@index([tenantId])
}

// ──────────────────────────────────
// 프로젝트 관리
// ──────────────────────────────────

model Project {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  code        String    // PJ-001
  name        String
  description String?
  status      String    @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  startDate   DateTime
  endDate     DateTime?
  manager     String?
  budget      Decimal?  @db.Decimal(18, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ──────────────────────────────────
// 부서 관리
// ──────────────────────────────────

model Department {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  code        String    // DP-001
  name        String
  description String?
  manager     String?
  budget      Decimal?  @db.Decimal(18, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ──────────────────────────────────
// 품목 관리
// ──────────────────────────────────

model Product {
  id            String    @id @default(uuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  code          String    // P-001
  name          String
  category      String?   // 직접재료, 간접재료, 부품 등
  unit          String?   // EA, KG, M 등
  standardCost  Decimal?  @db.Decimal(18, 2)
  description   String?
  currentStock  Int       @default(0)          // 현재 재고 수량
  avgCost       Decimal   @default(0) @db.Decimal(18, 2) // 이동평균 단가
  safetyStock   Int       @default(0)          // 안전 재고
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  inventoryTransactions InventoryTransaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ──────────────────────────────────
// 매출/매입 관리
// ──────────────────────────────────

// 거래명세서
model Trade {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  tradeType      String    // SALES (매출), PURCHASE (매입)
  tradeNo        String    // 거래번호 (자동 채번)
  tradeDate      DateTime
  dueDate        DateTime? // 결제 예정일
  vendorId       String
  vendor         Vendor    @relation(fields: [vendorId], references: [id])
  supplyAmount   Decimal   @db.Decimal(18, 2) // 공급가액
  taxAmount      Decimal   @db.Decimal(18, 2) // 세액
  totalAmount    Decimal   @db.Decimal(18, 2) // 합계
  paidAmount     Decimal   @default(0) @db.Decimal(18, 2) // 입금/출금 완료 금액
  status         String    @default("DRAFT") // DRAFT, CONFIRMED, PARTIAL_PAID, PAID, CANCELLED
  journalEntryId String?   @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  taxInvoiceId   String?
  description    String?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items    TradeItem[]
  payments Payment[]

  @@unique([tenantId, tradeNo])
  @@index([tenantId])
  @@index([tradeDate])
  @@index([tradeType])
}

// 거래 품목
model TradeItem {
  id            String  @id @default(uuid())
  tradeId       String
  trade         Trade   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  itemName      String
  specification String?
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(18, 2)
  amount        Decimal @db.Decimal(18, 2)
  note          String?

  @@index([tradeId])
}

// 입금/출금
model Payment {
  id             String        @id @default(uuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  tradeId        String
  trade          Trade         @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  paymentDate    DateTime
  amount         Decimal       @db.Decimal(18, 2)
  paymentMethod  String        // CASH, BANK_TRANSFER, CARD, NOTE
  journalEntryId String?       @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  note           String?
  createdAt      DateTime      @default(now())

  @@index([tradeId])
  @@index([tenantId])
}

// ──────────────────────────────────
// 경비 정산
// ──────────────────────────────────

model ExpenseClaim {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  claimNo        String    // EC-YYYYMMDD-NNN (자동 채번)
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id])
  title          String
  claimDate      DateTime  @db.Date
  totalAmount    Decimal   @default(0) @db.Decimal(18, 2)
  status         String    @default("DRAFT") // DRAFT | PENDING_APPROVAL | APPROVED | REJECTED | SETTLED
  memo           String?
  settledAt      DateTime?
  journalEntryId String?   @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  items          ExpenseClaimItem[]

  @@unique([tenantId, claimNo])
  @@index([tenantId])
}

model ExpenseClaimItem {
  id             String       @id @default(uuid())
  expenseClaimId String
  expenseClaim   ExpenseClaim @relation(fields: [expenseClaimId], references: [id], onDelete: Cascade)
  category       String       // 교통비 | 식비 | 숙박비 | 회의비 | 사무용품 | 기타
  description    String
  amount         Decimal      @db.Decimal(18, 2)
  expenseDate    DateTime     @db.Date
  receiptUrl     String?

  @@index([expenseClaimId])
}

// ──────────────────────────────────
// 재고 관리
// ──────────────────────────────────

model InventoryTransaction {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  txNo           String    // IV-YYYYMMDD-NNN (자동 채번)
  txType         String    // IN (입고) | OUT (출고) | ADJUST (조정)
  txDate         DateTime  @db.Date
  productId      String
  product        Product   @relation(fields: [productId], references: [id])
  quantity       Int       // 수량 (조정 시 음수 가능)
  unitCost       Decimal   @db.Decimal(18, 2)  // 단가
  totalCost      Decimal   @db.Decimal(18, 2)  // 총액
  reason         String?   // 입고사유/출고사유/조정사유
  tradeId        String?   // 매출/매입 연동 시
  journalEntryId String?   @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  beforeStock    Int       // 변동 전 재고
  afterStock     Int       // 변동 후 재고
  createdAt      DateTime  @default(now())

  @@unique([tenantId, txNo])
  @@index([tenantId])
  @@index([productId])
  @@index([txDate])
}

// ──────────────────────────────────
// 은행/계좌 관리
// ──────────────────────────────────

model BankAccount {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  bankName        String             // 은행명
  accountNumber   String             // 계좌번호
  accountHolder   String             // 예금주
  currency        String   @default("KRW")
  balance         Decimal  @default(0) @db.Decimal(18, 2) // 현재 잔액
  accountId       String             // 계정과목 FK (보통예금 등)
  account         Account  @relation(fields: [accountId], references: [id])
  status          String   @default("ACTIVE") // ACTIVE | INACTIVE
  memo            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    BankTransaction[]

  @@unique([tenantId, accountNumber])
  @@index([tenantId])
}

model BankTransaction {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  bankAccountId   String
  bankAccount     BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  txNo            String        // BA-YYYYMMDD-NNN (자동 채번)
  txType          String        // DEPOSIT (입금) | WITHDRAW (출금) | TRANSFER (이체)
  txDate          DateTime      @db.Date
  amount          Decimal       @db.Decimal(18, 2)
  balance         Decimal       @db.Decimal(18, 2) // 거래 후 잔액
  counterparty    String?       // 상대방
  description     String?       // 적요
  paymentId       String?       // Payment 연동 (선택)
  journalEntryId  String?       @unique
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdAt       DateTime      @default(now())

  @@unique([tenantId, txNo])
  @@index([tenantId])
  @@index([bankAccountId])
  @@index([txDate])
}

// ──────────────────────────────────
// 전자세금계산서 품목
// ──────────────────────────────────

model TaxInvoiceItem {
  id              String     @id @default(uuid())
  taxInvoiceId    String
  taxInvoice      TaxInvoice @relation(fields: [taxInvoiceId], references: [id], onDelete: Cascade)
  sequenceNo      Int        // 일련번호
  itemDate        DateTime?  // 거래일
  itemName        String?    // 품목명
  specification   String?    // 규격
  quantity        Decimal?   @db.Decimal(18, 4)
  unitPrice       Decimal?   @db.Decimal(18, 2)
  supplyAmount    Decimal    @db.Decimal(18, 2) // 공급가액
  taxAmount       Decimal    @db.Decimal(18, 2) // 세액
  remark          String?

  @@index([taxInvoiceId])
}

// ──────────────────────────────────
// 연말정산
// ──────────────────────────────────

model YearEndSettlement {
  id                String   @id @default(uuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year              Int

  // 총급여 (PayrollRecord 집계)
  annualGrossPay    Decimal  @db.Decimal(18, 2)

  // 인적공제
  dependents        Int      @default(1)        // 부양가족 수 (본인 포함)
  dependentsUnder20 Int      @default(0)        // 20세 이하 자녀
  dependentsOver70  Int      @default(0)        // 70세 이상 경로우대

  // 보험료
  insurancePremium       Decimal @default(0) @db.Decimal(18, 2)

  // 의료비
  medicalExpense         Decimal @default(0) @db.Decimal(18, 2)
  medicalExpenseSevere   Decimal @default(0) @db.Decimal(18, 2) // 난임/중증

  // 교육비
  educationExpense       Decimal @default(0) @db.Decimal(18, 2) // 본인
  educationExpenseChild  Decimal @default(0) @db.Decimal(18, 2) // 자녀

  // 기부금
  donationPolitical      Decimal @default(0) @db.Decimal(18, 2)
  donationLegal          Decimal @default(0) @db.Decimal(18, 2)
  donationDesignated     Decimal @default(0) @db.Decimal(18, 2)

  // 신용카드 등
  creditCardUsage        Decimal @default(0) @db.Decimal(18, 2)
  debitCardUsage         Decimal @default(0) @db.Decimal(18, 2)
  cashReceiptUsage       Decimal @default(0) @db.Decimal(18, 2)
  traditionalMarket      Decimal @default(0) @db.Decimal(18, 2) // 전통시장
  publicTransport        Decimal @default(0) @db.Decimal(18, 2) // 대중교통

  // 주택/연금
  housingLoanInterest    Decimal @default(0) @db.Decimal(18, 2)
  housingRent            Decimal @default(0) @db.Decimal(18, 2)
  pensionSaving          Decimal @default(0) @db.Decimal(18, 2)

  // 계산 결과
  earnedIncomeDeduction   Decimal @default(0) @db.Decimal(18, 2) // 근로소득공제
  earnedIncome            Decimal @default(0) @db.Decimal(18, 2) // 근로소득금액
  personalDeduction       Decimal @default(0) @db.Decimal(18, 2) // 인적공제
  specialDeduction        Decimal @default(0) @db.Decimal(18, 2) // 특별소득공제
  otherDeduction          Decimal @default(0) @db.Decimal(18, 2) // 그 외 소득공제
  taxableIncome           Decimal @default(0) @db.Decimal(18, 2) // 과세표준
  calculatedTax           Decimal @default(0) @db.Decimal(18, 2) // 산출세액
  taxCredit               Decimal @default(0) @db.Decimal(18, 2) // 세액공제
  determinedTax           Decimal @default(0) @db.Decimal(18, 2) // 결정세액
  alreadyPaidTax          Decimal @default(0) @db.Decimal(18, 2) // 기납부세액
  finalTax                Decimal @default(0) @db.Decimal(18, 2) // 환급(-) / 납부(+)

  status             String   @default("DRAFT") // DRAFT, CALCULATED, FINALIZED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([employeeId, year])
  @@index([employeeId])
}

// ──────────────────────────────────
// 전자신고
// ──────────────────────────────────

model TaxFiling {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  filingType      String   // VAT, CORPORATE, WITHHOLDING
  year            Int
  period          String   // Q1~Q4 (부가세), ANNUAL (법인세), YYYY-MM (원천세)

  filingData      Json     // 신고서 데이터

  status          String   @default("DRAFT") // DRAFT, GENERATED, EXPORTED, FILED, ACCEPTED, REJECTED
  generatedAt     DateTime?
  exportedAt      DateTime?
  filedAt         DateTime?
  filingReference String?  // 홈택스 접수번호

  taxableAmount   Decimal  @default(0) @db.Decimal(18, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(18, 2)

  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, filingType, year, period])
  @@index([tenantId])
  @@index([filingType])
}
